# ── Backend ────────────────────────────────────────────────────────────────
# Port FastAPI (défaut : 8000)
BACKEND_PORT=8000
# Origines frontend autorisées pour le CORS
MEDISCAN_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
# Taille max d'upload image (10 Mo)
MEDISCAN_MAX_UPLOAD_BYTES=10485760
# Timeout de téléchargement des images distantes (secondes)
MEDISCAN_REMOTE_IMAGE_TIMEOUT_SECONDS=15

# ── Modèles / performance ──────────────────────────────────────────────────
# Threads CPU pour PyTorch (défaut : 1)
MEDISCAN_TORCH_THREADS=1

# ── MongoDB (optionnel — enrichissement des résultats) ────────────────────
# MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/

# ── LLM — Analyse IA (obligatoire pour la fonctionnalité Analyse IA) ──────
# Créer une clé sur https://console.groq.com → API Keys
GROQ_KEY_API=
MEDISCAN_GROQ_MODEL=llama-3.3-70b-versatile
# Nombre max de résultats injectés dans la synthèse IA
MEDISCAN_MAX_CONCLUSION_RESULTS=6

# ── Email de contact (SMTP) ────────────────────────────────────────────────
# Exemple avec Google Workspace, Outlook ou Mailgun SMTP.
# Le formulaire contact envoie vers MEDISCAN_CONTACT_TO_EMAIL.
MEDISCAN_SMTP_HOST=
MEDISCAN_SMTP_PORT=587
MEDISCAN_SMTP_USERNAME=
MEDISCAN_SMTP_PASSWORD=
MEDISCAN_SMTP_USE_TLS=true
MEDISCAN_SMTP_USE_SSL=false
MEDISCAN_CONTACT_FROM_EMAIL=
MEDISCAN_CONTACT_TO_EMAIL=
# Optionnel : adresse de reply-to par défaut si besoin
# MEDISCAN_CONTACT_REPLY_TO_EMAIL=

# ── Chemins (optionnel, valeurs par défaut dans runtime.py) ───────────────
# DATA_DIR=data/roco_train_full
# ARTIFACTS_DIR=artifacts
